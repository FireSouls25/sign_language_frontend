# Backend URL configuration
# For local development with ngrok, set your ngrok URL here
# Example: BACKEND_URL=https://abc123.ngrok.io
# BACKEND_URL=https://sign-language-backend-vqq1.onrender.com
BACKEND_URL=https://annotate-flatbed-divisive.ngrok-free.dev

# WebSocket URL - must match BACKEND_URL domain
# Example: BACKEND_WS_URL=wss://abc123.ngrok.io
# BACKEND_WS_URL=wss://sign-language-backend-vqq1.onrender.com
BACKEND_WS_URL=wss://annotate-flatbed-divisive.ngrok-free.dev